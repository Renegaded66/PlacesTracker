<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tripDetailRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000"
    android:fitsSystemWindows="false">

    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <android.webkit.WebView
            android:id="@+id/tripCesiumWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/tvNoLocation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#40000000"
            android:gravity="center"
            android:text="@string/no_location_available"
            android:textColor="@android:color/white"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/top_shadow_gradient" />

        <ImageButton
            android:id="@+id/btnFullscreenMap"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:elevation="4dp"
            android:src="@drawable/ic_fullscreen"
            android:contentDescription="@string/fullscreen"
            app:tint="?attr/colorOnSurface" />
    </FrameLayout>

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarTrip"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIcon="@drawable/ic_arrow_back"
        android:layout_marginTop="19dp"
        app:title="@string/trip_details"
        app:titleTextColor="@android:color/white" />

    <androidx.cardview.widget.CardView
        android:id="@+id/bottomSheetTrip"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:behavior_hideable="false"
        app:behavior_peekHeight="120dp"
        app:cardBackgroundColor="?android:attr/windowBackground"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/tripSheetHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <View
                    android:id="@+id/dragHandle"
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:background="#40808080" />

                <TextView
                    android:id="@+id/tvTripDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    tools:text="Sommerurlaub 2024" />
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    android:layout_alignParentStart="true"
                    android:layout_marginBottom="90dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/timeline_gradient" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvDayIndicator"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="6dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="?attr/colorPrimary">
                        <TextView
                            android:id="@+id/tvDayNumber"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="1"
                            android:textStyle="bold"
                            android:textSize="16sp"/>
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/tripNestedScroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="60dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:id="@+id/tvTripDetailNotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="?android:attr/textColorSecondary"
                            android:textSize="16sp"
                            android:visibility="gone"
                            tools:text="Das ist eine Notiz zum gesamten Trip."
                            tools:visibility="visible" />

                        <LinearLayout
                            android:id="@+id/llTripFlags"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cvTripCountryName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            app:cardBackgroundColor="?attr/colorSurfaceVariant"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="4dp">

                            <TextView
                                android:id="@+id/tvTripCountryNamePopup"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:textSize="12sp"
                                tools:text="Deutschland" />
                        </com.google.android.material.card.MaterialCardView>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvTripDetailStops"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:paddingBottom="100dp"
                            android:clipToPadding="false"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>
            </RelativeLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
