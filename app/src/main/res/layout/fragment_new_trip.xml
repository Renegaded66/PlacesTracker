<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/tripScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvHeaderTrip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deine Reise"
                android:textColor="#E0E0E0"
                android:textSize="34sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:background="?attr/colorPrimary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"/>

            <!-- Titel Input -->
            <EditText
                android:id="@+id/inputTripTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Name der Reise..."
                android:background="@null"
                android:textColor="#FFFFFF"
                android:textColorHint="#66FFFFFF"
                android:textSize="22sp"
                android:fontFamily="serif-medium"
                android:inputType="textCapSentences"
                android:layout_marginBottom="24dp"/>

            <!-- Cover Image -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="20dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="32dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/ivTripCoverPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/vorschaubild"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#66000000"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddTripCover"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Cover wählen"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="#FFFFFF"
                        app:icon="@drawable/ic_add"
                        app:iconTint="#FFFFFF" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Map Preview -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="250dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="20dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="32dp">
                <android.webkit.WebView
                    android:id="@+id/tripMapPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Stations Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stationen &amp; Zeitpunkte"
                android:textColor="#BDBDBD"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTripStops"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddStop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Station hinzufügen"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#33FFFFFF"
                android:textColor="#FFFFFF"
                app:icon="@drawable/ic_add"
                app:iconTint="?attr/colorPrimary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"/>

            <!-- Notizen -->
            <EditText
                android:id="@+id/inputTripNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Beschreibung der Reise..."
                android:background="@drawable/bg_diary_input"
                android:textColor="#FFFFFF"
                android:textColorHint="#44FFFFFF"
                android:textSize="16sp"
                android:fontFamily="serif"
                android:gravity="top"
                android:minLines="4"
                android:padding="16dp"
                android:layout_marginBottom="32dp"/>


            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAutoTrip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Automatische Reise"
                android:textColor="#FFFFFF"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveTrip"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:layout_margin="24dp"
        android:text="Reise speichern"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:fontFamily="serif-medium"
        app:cornerRadius="16dp"
        app:backgroundTint="?attr/colorPrimary"
        android:textColor="?attr/colorOnPrimary"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
